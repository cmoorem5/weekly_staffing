# Copy to .env (gitignored) and fill in real values. All settings are
# optional for local development: with no .env at all, Django uses the dev
# secret key, DEBUG on, and the console email backend (emails print to the
# runserver terminal instead of being sent).

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Comma-separated emails that receive server-error reports (only when
# DJANGO_DEBUG is off and real email is configured below). Optional.
# DJANGO_ADMINS=you@example.org

# --- Database ---
# Default is SQLite (bmf_staffing/db.sqlite3) — nothing to configure.
# To run Crew Hub on PostgreSQL instead, uncomment and fill these in,
# then: pip install "psycopg[binary]" && python manage.py migrate
# DJANGO_DB_ENGINE=postgresql
# DJANGO_DB_NAME=crew_hub
# DJANGO_DB_USER=crew_hub
# DJANGO_DB_PASSWORD=change-me
# DJANGO_DB_HOST=localhost
# DJANGO_DB_PORT=5432

# --- AOC Daily Report email ---
# Keep the console backend for dev; switch to smtp for real sends.
# Verify your settings any time with:
#   python manage.py send_test_email you@example.org
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.example.org
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=aoc-report@example.org
DJANGO_EMAIL_HOST_PASSWORD=change-me
DJANGO_EMAIL_USE_TLS=true
DJANGO_DEFAULT_FROM_EMAIL=aoc-report@example.org

# --- Sending through Outlook -------------------------------------------
# Work / Microsoft 365 account (name@yourorg.org):
#   DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
#   DJANGO_EMAIL_HOST=smtp.office365.com
#   DJANGO_EMAIL_PORT=587
#   DJANGO_EMAIL_USE_TLS=true
#   DJANGO_EMAIL_HOST_USER=you@yourorg.org
#   DJANGO_EMAIL_HOST_PASSWORD=your-password-or-app-password
#   DJANGO_DEFAULT_FROM_EMAIL=you@yourorg.org
#
# Personal Outlook.com / Hotmail account: same as above but
#   DJANGO_EMAIL_HOST=smtp-mail.outlook.com
#
# Notes:
# * DJANGO_DEFAULT_FROM_EMAIL must be the same mailbox you sign in with —
#   Outlook rejects sends "from" a different address.
# * If sign-in fails (535 auth error), create an **app password** and use
#   it as DJANGO_EMAIL_HOST_PASSWORD: account.microsoft.com -> Security ->
#   Advanced security options -> App passwords (requires two-step
#   verification to be turned on).
# * On Microsoft 365 work accounts, IT may also need to enable
#   "Authenticated SMTP" for your mailbox (admin center -> user -> Mail ->
#   Manage email apps).

# Comma-separated recipients for the submitted report email.
AOC_REPORT_RECIPIENTS=ops-team@example.org,leadership@example.org

# External Equipment OOS / MISS dashboard link shown on the report.
AOC_EQUIPMENT_DASHBOARD_URL=https://metabase.example.org/public/dashboard/your-dashboard-id

# --- Base weather strip (Today board) -----------------------------------
# "Base:ICAO" pairs for the nearest METAR-reporting airport per base.
# Data comes from aviationweather.gov (free, no key; needs internet).
# Leave unset for the defaults below; set to empty to turn the strip off.
# AOC_WEATHER_STATIONS=Bedford:KBED,Lawrence:KLWM,Manchester:KMHT,Mansfield:KOWD,Plymouth:KPYM
