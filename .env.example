# Copy to .env (gitignored) and fill in real values. All settings are
# optional for local development: with no .env at all, Django uses the dev
# secret key, DEBUG on, and the console email backend (emails print to the
# runserver terminal instead of being sent).

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- AOC Daily Report email ---
# Keep the console backend for dev; switch to smtp for real sends.
DJANGO_EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
DJANGO_EMAIL_HOST=smtp.example.org
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=aoc-report@example.org
DJANGO_EMAIL_HOST_PASSWORD=change-me
DJANGO_EMAIL_USE_TLS=true
DJANGO_DEFAULT_FROM_EMAIL=aoc-report@example.org

# Comma-separated recipients for the submitted report email.
AOC_REPORT_RECIPIENTS=ops-team@example.org,leadership@example.org

# External Equipment OOS / MISS dashboard link shown on the report.
AOC_EQUIPMENT_DASHBOARD_URL=https://metabase.example.org/public/dashboard/your-dashboard-id
